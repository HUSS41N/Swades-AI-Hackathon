NODE_ENV=development
# Matches `docker compose` postgres service (see README "Postgres for local dev")
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/attack_capital
API_PORT=3000
# Browser origins allowed to call this API (comma-separated). Required for production:
# e.g. WEB_ORIGIN=http://localhost:3001,https://your-app.vercel.app
# Must match the site URL exactly (scheme + host, no trailing slash).
WEB_ORIGIN=http://localhost:3001
# Required for POST /api/transcribe (Whisper). Do not commit real keys.
OPENAI_API_KEY=
# Optional: enables POST /api/transcribe/async job queue + worker (e.g. redis://localhost:6379)
REDIS_URL=
